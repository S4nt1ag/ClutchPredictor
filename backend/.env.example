# Copie para .env e preencha com sua API key

# Opção 1: TheRundown (recomendado - plano gratuito com mais requests)
# Obtenha sua chave em: https://therundown.io/pricing/api
THERUNDOWN_API_KEY=sua_api_key_aqui

# Opção 2: BallDon'tLie (alternativa)
# BALLDONTLIE_API_KEY=sua_api_key_aqui

# Para usar dados reais: therundown | Para usar dados mock: mock (padrão)
DATA_PROVIDER=therundown